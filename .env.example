# ============================================================
# EcoPoints — environment variables
# คัดลอกไฟล์นี้เป็น .env.local แล้วใส่ค่าจริง
# ============================================================

# ---------- PUBLIC (ส่งไปฝั่ง browser ได้ — ปลอดภัย) ----------

# Supabase → Project Settings → API → Project URL
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxxxxxx.supabase.co

# Supabase → Project Settings → API → Project API keys → anon / public
# คีย์นี้ถูกจำกัดสิทธิ์ด้วย RLS อยู่แล้ว จึงเปิดเผยได้
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOi...

# URL ของเว็บ ใช้ทำ redirect ตอน login (dev: http://localhost:3000)
NEXT_PUBLIC_SITE_URL=http://localhost:3000


# ---------- SERVER-ONLY (ห้ามหลุดไปฝั่ง browser เด็ดขาด) ----------
# ห้ามเติม prefix NEXT_PUBLIC_ ให้สองตัวข้างล่างนี้โดยเด็ดขาด
# ห้าม import เข้า client component ("use client") โดยเด็ดขาด
# ใช้ได้เฉพาะใน Route Handler (app/api/**) และ Server Component เท่านั้น

# Supabase → Project Settings → API → Project API keys → service_role (secret)
# คีย์นี้ข้าม RLS ได้ทั้งหมด = ใครได้ไปคือยึดฐานข้อมูลได้ทั้งใบ
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOi...

# Google AI Studio → Get API key  (https://aistudio.google.com/app/apikey)
GEMINI_API_KEY=AIza...

# (ไม่บังคับ) เปลี่ยนโมเดลได้โดยไม่ต้องแก้โค้ด — ค่า default คือ gemini-3.1-flash-lite
#
# หมายเหตุ: อย่าใช้ gemini-2.0-flash / gemini-2.5-flash — API key ที่สร้างใหม่
# จะได้โควตา free tier = 0 กับโมเดลรุ่นนั้น ยิงไปเจอ 429 ทุกครั้ง
# ส่วน gemini-3.5-flash เป็นโมเดลสาย "คิดก่อนตอบ" ใช้เวลาเกิน 90 วินาที ช้าเกินไป
# GEMINI_MODEL=gemini-3.1-flash-lite
